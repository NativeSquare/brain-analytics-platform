{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "skipLibCheck": true,
  "moduleResolution": "Bundler",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "babel.config.js"
  ]
}
